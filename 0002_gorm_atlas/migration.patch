@@ -0,0 +1,38 @@
+load("@aspect_bazel_lib//lib:write_source_files.bzl", "write_source_files")
+load("@rules//pkg/atlas:atlas.bzl", "atlas_migrations_mysql", "atlas_migrations_mysql_test")
+load("@rules_go//go:def.bzl", "go_library")
+
+atlas_migrations_mysql(
+    name = "atlas_migrations",
+    migrations = glob(
+        [
+            "migrations/*.sql",
+            "migrations/atlas.sum",
+        ],
+        allow_empty = True,
+    ),
+    schema = "//cmd/atlas:atlas_schema",
+)
+
+# gazelle:exclude db.go
+# keep
+go_library(
+    name = "db",
+    srcs = ["db.go"],
+    embedsrcs = [":atlas_migrations"],
+    importpath = "github.com/mindful-hq/earth-email-service/db",
+    visibility = ["//cmd/earth_email_service:__pkg__"],
+)
+
+atlas_migrations_mysql_test(
+    name = "atlas_migrations_test",
+    migrations = ":atlas_migrations",
+)
+
+write_source_files(
+    name = "atlas_migration_sources",
+    files = {
+        "migrations": ":atlas_migrations",
+    },
+    visibility = ["//visibility:public"],
+)
