+
+go_library(
+    name = "atlas_lib",
+    srcs = ["main.go"],
+    importpath = "github.com/mindful-hq/earth-email-service/cmd/atlas",
+    visibility = ["//visibility:private"],
+    deps = [
+        "//internal/database/model/model_v1",
+        "@io_ariga_atlas_provider_gorm//gormschema",
+    ],
+)
+
+go_binary(
+    name = "atlas",
+    embed = [":atlas_lib"],
+    visibility = ["//visibility:public"],
+)
+
+run_binary(
+    name = "atlas_schema",
+    outs = ["schema.sql"],
+    args = [
+        "$(location schema.sql)",
+    ],
+    tool = ":atlas",
+    visibility = ["//visibility:public"],
+)
diff --git a/cmd/atlas/main.go b/cmd/atlas/main.go
new file mode 100644
index 0000000..0a0033e
--- /dev/null
+++ b/cmd/atlas/main.go
@@ -0,0 +1,37 @@
+package main
+
+import (
+	"log"
+	"os"
+
+	"ariga.io/atlas-provider-gorm/gormschema"
+	modelv1 "github.com/mindful-hq/earth-email-service/internal/database/model/model_v1"
+)
+
+func main() {
+	var err error
+
+	if len(os.Args) != 2 {
+		log.Fatal("usage: atlas <output_file>")
+	}
+
+	var stmts string
+	if stmts, err = gormschema.New("mysql").Load(
+		new(modelv1.EmailConfig),
+		new(modelv1.EmailTemplate),
+		new(modelv1.Email),
+		new(modelv1.EmailSendEmailOutbox),
+		new(modelv1.OperationSubscription),
+		new(modelv1.Operation),
+	); err != nil {
+		log.Fatal(err)
+	}
+
+	if err = os.WriteFile(
+		os.Args[1],
+		[]byte(stmts),
+		0o644,
+	); err != nil {
+		log.Fatal(err)
+	}
+}
