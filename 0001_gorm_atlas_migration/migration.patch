+
+atlas_migrations_test(
+    name = "atlas_migrations_test",
+    migrations = ":atlas_migrations",
+)
+
+write_source_files(
+    name = "atlas_migration_sources",
+    files = {
+        "migrations": ":atlas_migrations",
+    },
+    visibility = ["//visibility:public"],
+)
